<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ categoria }} - Mercado CLN</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body style="font-family: sans-serif; text-align: center; background-color: #f8f9fa; margin: 0; padding: 20px;">

    <header style="background: #007bff; color: white; padding: 20px; border-radius: 0 0 20px 20px; margin-bottom: 20px;">
        <h1 style="margin: 0;">Categoría: {{ categoria }}</h1>
        <br>
        <a href="/" style="color: white; font-weight: bold; text-decoration: none; border: 1px solid white; padding: 5px 15px; border-radius: 20px;">⬅ Volver al Inicio</a>
    </header>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px;">
        {% for p in productos %}
        <div style="background: white; border-radius: 15px; width: 250px; padding: 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); text-align: center;">
            <img src="{{ p.imagen }}" style="width: 100%; height: 180px; object-fit: cover; border-radius: 10px;">
            <h3 style="margin: 10px 0; color: #333;">{{ p.nombre }}</h3>
            <p style="font-size: 1.5em; color: #28a745; font-weight: bold; margin: 10px 0;">${{ p.precio }}</p>
            
            <form action="/pedido" method="POST">
                <input type="hidden" name="total" value="{{ p.precio }}">
                <input type="hidden" name="envio" value="40"> <input type="text" name="nombre" placeholder="Tu nombre" required style="width: 90%; margin-bottom: 5px; padding: 5px;">
                <input type="text" name="colonia" placeholder="Tu colonia" required style="width: 90%; margin-bottom: 5px; padding: 5px;">
                <input type="text" name="direccion" placeholder="Calle y número" required style="width: 90%; margin-bottom: 10px; padding: 5px;">
                <button type="submit" style="background: #25D366; color: white; border: none; padding: 10px 20px; border-radius: 5px; font-weight: bold; cursor: pointer; width: 100%;">
                    Pedir por WhatsApp
                </button>
            </form>
        </div>
        {% else %}
        <div style="margin-top: 50px;">
            <p style="color: #666; font-style: italic;">Aún no hay productos en esta sección.</p>
        </div>
        {% endfor %}
    </div>

    <footer style="margin-top: 40px; color: #999;">
        <p>&copy; 2026 Mercado en Línea Culiacán</p>
    </footer>

</body>
</html>
